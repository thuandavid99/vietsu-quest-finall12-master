function beep(f,d,v=.15,t='sine',dy=0){if(!AC)try{AC=new(window.AudioContext||window.webkitAudioContext)()}catch(e){return}const o=AC.createOscillator(),g=AC.createGain();o.connect(g);g.connect(AC.destination);o.type=t;o.frequency.value=f;g.gain.setValueAtTime(v,AC.currentTime+dy);g.gain.exponentialRampToValueAtTime(.001,AC.currentTime+dy+d);o.start(AC.currentTime+dy);o.stop(AC.currentTime+dy+d+.05)}
const sfxOk=()=>{beep(440,.08);beep(660,.12,.15,'sine',.09)};
