      <button class="fc-btn-add" onclick="addPair()">＋ Thêm thẻ</button>
      <button class="fc-btn-secondary" onclick="showPasteModal()">📋 Nhập từ bảng</button>
      <span class="fc-import-hint">Định dạng: Câu hỏi, Đáp án (mỗi dòng 1 thẻ)</span>
    </div>
    <button class="fc-btn-primary" id="btnStart" style="opacity:.5;margin-top:16px" disabled onclick="startCustomDeck()">▶ Bắt đầu học</button>
  </div>
</div>
</div>
<div class="fc-modal-bg" id="pasteModal">
  <div class="fc-modal-box">
    <h3>📋 Nhập từ bảng / CSV</h3>
    <p>Mỗi dòng một thẻ, dùng dấu phẩy hoặc tab: <code>Câu hỏi, Đáp án</code></p>
    <textarea class="fc-paste-area" id="pasteArea" placeholder="Dán nội dung vào đây..."></textarea>
    <div style="display:flex;gap:10px"><button class="fc-btn-primary" onclick="importPaste()">Nhập</button><button class="fc-btn-secondary" onclick="closePasteModal()">Hủy</button></div>
  </div>
</div>`;
  renderPairList();
  document.addEventListener('click',()=>{if(!AC)try{AC=new(window.AudioContext||window.webkitAudioContext)()}catch(e){}},{once:true});
}

function switchTab(tab,btn){
  document.querySelectorAll('.fc-tab').forEach(b=>b.classList.remove('active'));btn.classList.add('active');S.activeTab=tab;
  if(el('fcTabBuiltin'))el('fcTabBuiltin').style.display=tab==='builtin'?'':'none';
  if(el('fcTabCreate'))el('fcTabCreate').style.display=tab==='create'?'':'none';
}
function addPair(q='',a=''){S.customPairs.push({q,a});renderPairList()}
function removePair(i){if(S.customPairs.length<=1)return;S.customPairs.splice(i,1);renderPairList()}
function renderPairList(){const l=el('pairList');if(!l)return;l.innerHTML=S.customPairs.map((p,i)=>`<div class="fc-pair"><input type="text" placeholder="Câu hỏi" value="${esc(p.q)}" oninput="S.customPairs[${i}].q=this.value;checkCustomValid()"/><input type="text" placeholder="Đáp án" value="${esc(p.a)}" oninput="S.customPairs[${i}].a=this.value;checkCustomValid()"/><button class="fc-pair-del" onclick="removePair(${i})">✕</button></div>`).join('');checkCustomValid()}
function checkCustomValid(){const ok=S.customPairs.filter(p=>p.q.trim()&&p.a.trim()).length>=2;const b=el('btnStart');if(b){b.disabled=!ok;b.style.opacity=ok?'1':'.5'}}
function startCustomDeck(){const cards=S.customPairs.filter(p=>p.q.trim()&&p.a.trim());if(cards.length<2){showToast('⚠️ Cần ít nhất 2 thẻ có nội dung!');return;}selectDeckObj({id:'custom',name:S.customName||'Bộ thẻ của tôi',emoji:'✏️',cards})}
function showPasteModal(){el('pasteModal')?.classList.add('open')}
function closePasteModal(){el('pasteModal')?.classList.remove('open')}
function importPaste(){const raw=el('pasteArea')?.value||'';const lines=raw.split('\n').map(l=>l.trim()).filter(Boolean);const pairs=[];lines.forEach(line=>{const sep=line.includes('\t')?'\t':',';const parts=line.split(sep);if(parts.length<2)return;const q=parts[0].trim(),a=parts.slice(1).join(sep).trim();if(q&&a)pairs.push({q,a})});if(!pairs.length){showToast('⚠️ Không nhận ra định dạng');return}S.customPairs=[...S.customPairs,...pairs];renderPairList();closePasteModal();showToast('✅ Đã nhập '+pairs.length+' thẻ!')}
function selectDeck(id){const d=DECKS.find(d=>d.id===id);if(d)selectDeckObj(d)}
function selectDeckObj(deck){S.deck=deck;renderModeSelect()}

function renderModeSelect(){S.screen='mode';const d=S.deck;app.innerHTML=`<div class="fc-screen">
<div class="fc-mode-header"><div style="font-size:2.8rem;margin-bottom:10px">${d.emoji}</div><div class="deck-title">${esc(d.name)}</div><div class="deck-info">${d.cards.length} thẻ · Chọn chế độ học</div></div>
<div class="fc-mode-grid">
  <div class="fc-mode-card" onclick="startStudy('flashcard')"><span class="fc-mode-badge">Cổ điển</span><span class="fc-mode-icon">🃏</span><div class="fc-mode-name">Lật thẻ ghi nhớ</div><div class="fc-mode-desc">Xem câu hỏi → tự nhớ → lật thẻ xem đáp án. Tự đánh giá đã nhớ hay chưa.</div></div>
  <div class="fc-mode-card" onclick="startStudy('quiz')"><span class="fc-mode-icon">🎯</span><div class="fc-mode-name">Trắc nghiệm</div><div class="fc-mode-desc">4 đáp án mỗi câu. Điểm số tự động, phản hồi ngay sau mỗi câu.</div></div>
  <div class="fc-mode-card" onclick="startStudy('match')"><span class="fc-mode-icon">🔗</span><div class="fc-mode-name">Ghép đôi</div><div class="fc-mode-desc">Ghép thuật ngữ với định nghĩa. Rèn trí nhớ thị giác hiệu quả nhất.</div></div>
  <div class="fc-mode-card" onclick="startStudy('speed')"><span class="fc-mode-badge">Thách thức</span><span class="fc-mode-icon">⚡</span><div class="fc-mode-name">Đua tốc độ</div><div class="fc-mode-desc">Có timer đếm ngược. Cố nhớ trước khi xem đáp án và tự đánh giá.</div></div>
</div>
<div class="fc-start-row"><button class="fc-btn-secondary" onclick="renderHome()">← Bộ thẻ khác</button></div>
</div>`}

function startStudy(mode){S.mode=mode;S.cards=shuffle([...S.deck.cards]);S.idx=0;S.score=0;S.total=S.cards.length;S.log=[];S.flipped=false;S.answered=false;S.screen='study';if(mode==='flashcard')renderFlashcard();else if(mode==='quiz')renderQuiz();else if(mode==='match')renderMatch();else renderSpeed()}
function hudHTML(){const pct=Math.round(S.idx/S.total*100);const ml={flashcard:'🃏 Lật thẻ',quiz:'🎯 Trắc nghiệm',match:'🔗 Ghép đôi',speed:'⚡ Tốc độ'}[S.mode];return`<div class="fc-hud"><div class="fc-hud-stat"><span class="fc-hud-val">${S.score}</span><span class="fc-hud-lbl">Điểm</span></div><div class="fc-hud-stat"><span class="fc-hud-val">${S.idx}/${S.total}</span><span class="fc-hud-lbl">Câu</span></div><div class="fc-hud-progress"><div class="fc-hud-lbl">${ml}</div><div class="fc-prog-track"><div class="fc-prog-bar" style="width:${pct}%"></div></div></div><button class="fc-btn-secondary" style="font-size:.78rem;padding:6px 14px" onclick="renderModeSelect()">✕ Thoát</button></div>`}

function renderFlashcard(){if(S.idx>=S.total){renderResult();return}const card=S.cards[S.idx];S.flipped=false;app.innerHTML=`<div class="fc-screen">${hudHTML()}<div class="fc-flip-area" id="flipArea" onclick="flipCard()"><div class="fc-flip-inner"><div class="fc-face fc-face-front"><div class="fc-face-label">Câu hỏi</div><div class="fc-face-text">${esc(card.q)}</div><div class="fc-face-hint">Click để xem đáp án →</div></div><div class="fc-face fc-face-back"><div class="fc-face-label">Đáp án</div><div class="fc-face-text">${esc(card.a)}</div><div class="fc-face-hint">Tự đánh giá bên dưới</div></div></div></div><div class="fc-flip-nav"><button class="fc-nav-btn" onclick="fcPrev()" ${S.idx===0?'disabled':''}>◀</button><span class="fc-card-counter">${S.idx+1} / ${S.total}</span><button class="fc-nav-btn" onclick="fcSkip()">▶</button></div><div class="fc-flip-hint">Click vào thẻ để lật</div><div class="fc-self-mark" id="selfMark" style="display:none"><button class="fc-mark-btn fc-mark-learn" onclick="fcMark(false)">❌ Chưa nhớ</button><button class="fc-mark-btn fc-mark-know" onclick="fcMark(true)">✅ Đã nhớ</button></div></div>`}
function flipCard(){sfxFlip();S.flipped=!S.flipped;el('flipArea')?.classList.toggle('flipped',S.flipped);if(S.flipped){const sm=el('selfMark');if(sm)sm.style.display='flex'}}
function fcMark(know){const card=S.cards[S.idx];if(know){S.score++;sfxOk()}else sfxWrong();S.log.push({q:card.q,a:card.a,correct:know});S.idx++;renderFlashcard()}
function fcSkip(){const card=S.cards[S.idx];S.log.push({q:card.q,a:card.a,correct:false});S.idx++;renderFlashcard()}
function fcPrev(){if(S.idx>0){S.idx--;if(S.log.length>S.idx)S.log.pop()}renderFlashcard()}

function renderQuiz(){if(S.idx>=S.total){renderResult();return}S.answered=false;const card=S.cards[S.idx];const pool=S.cards.filter((_,i)=>i!==S.idx).map(c=>c.a);const wrongs=shuffle(pool).slice(0,3);S.opts=shuffle([card.a,...wrongs]);const letters=['A','B','C','D'];const optsHTML=S.opts.map((o,i)=>`<button class="fc-opt" id="opt${i}" onclick="quizAnswer(${i},this)"><span class="opt-letter">${letters[i]}</span>${esc(o)}</button>`).join('');app.innerHTML=`<div class="fc-screen">${hudHTML()}<div class="fc-quiz-question"><div class="fc-quiz-q-label">Câu ${S.idx+1}</div><div class="fc-quiz-q-text">${esc(card.q)}</div></div><div class="fc-quiz-opts">${optsHTML}</div><div id="quizFeedback"></div></div>`}
function quizAnswer(i,btn){if(S.answered)return;S.answered=true;const card=S.cards[S.idx];const correct=S.opts[i]===card.a;document.querySelectorAll('.fc-opt').forEach(b=>{b.disabled=true;if(b.textContent.includes(card.a))b.classList.add('opt-correct')});if(!correct){btn.classList.add('opt-wrong');sfxWrong()}else{S.score++;sfxOk()}S.log.push({q:card.q,a:card.a,correct});const fb=el('quizFeedback');fb.innerHTML=`<div class="fc-quiz-feedback ${correct?'fb-ok':'fb-bad'}">${correct?'✅ Chính xác!':'❌ Sai — Đáp án đúng đã được tô xanh'}</div>`;setTimeout(()=>{S.idx++;renderQuiz()},1500)}

function renderMatch(){const N=Math.min(6,S.total);const picked=S.cards.slice(0,N);S.matchLeft=shuffle(picked.map((c,i)=>({id:i,text:c.q,matched:false})));S.matchRight=shuffle(picked.map((c,i)=>({id:i,text:c.a,matched:false})));S.selectedL=null;S.selectedR=null;S.score=0;S.total=N;renderMatchBoard()}
function renderMatchBoard(){const lH=S.matchLeft.map((item,i)=>`<div class="fc-match-item ${item.matched?'matched':''}" id="ml${i}" onclick="selL(${i})">${esc(item.text)}</div>`).join('');const rH=S.matchRight.map((item,i)=>`<div class="fc-match-item ${item.matched?'matched':''}" id="mr${i}" onclick="selR(${i})">${esc(item.text)}</div>`).join('');app.innerHTML=`<div class="fc-screen">${hudHTML()}<div class="fc-match-hint">Click thẻ bên TRÁI rồi click thẻ khớp bên PHẢI để ghép đôi</div><div class="fc-match-grid"><div class="fc-match-col">${lH}</div><div class="fc-match-col">${rH}</div></div></div>`;if(S.selectedL!==null)el('ml'+S.selectedL)?.classList.add('selected');if(S.selectedR!==null)el('mr'+S.selectedR)?.classList.add('selected')}
function selL(i){if(S.matchLeft[i].matched)return;S.selectedL=i;renderMatchBoard();tryMatch()}
function selR(i){if(S.matchRight[i].matched)return;S.selectedR=i;renderMatchBoard();tryMatch()}
function tryMatch(){if(S.selectedL===null||S.selectedR===null)return;const li=S.matchLeft[S.selectedL],ri=S.matchRight[S.selectedR];if(li.id===ri.id){li.matched=ri.matched=true;S.score++;sfxMatch();S.selectedL=S.selectedR=null;renderMatchBoard();if(S.matchLeft.every(i=>i.matched)){setTimeout(()=>{S.log=S.matchLeft.map(l=>({q:l.text,a:S.matchRight.find(r=>r.id===l.id)?.text||'',correct:true}));S.idx=S.total;renderResult()},600)}}else{sfxWrong();const lEl=el('ml'+S.selectedL),rEl=el('mr'+S.selectedR);lEl?.classList.add('mismatch-anim');rEl?.classList.add('mismatch-anim');setTimeout(()=>{lEl?.classList.remove('mismatch-anim');rEl?.classList.remove('mismatch-anim');S.selectedL=S.selectedR=null;renderMatchBoard()},400)}}

let speedTmr=null;
function renderSpeed(){clearInterval(speedTmr);if(S.idx>=S.total){renderResult();return}S.speedShown=false;const card=S.cards[S.idx];let tLeft=15;app.innerHTML=`<div class="fc-screen">${hudHTML()}<div class="fc-speed-timer-bar"><div class="fc-speed-timer-fill" id="spBar" style="width:100%"></div></div><div class="fc-speed-card"><div class="fc-speed-card-label">Hãy nhớ đáp án…</div><div class="fc-speed-card-text">${esc(card.q)}</div><div class="fc-speed-answer" id="spAns"><strong>${esc(card.a)}</strong></div><div class="fc-speed-btns" id="spBtns"><button class="fc-speed-show" onclick="speedReveal()">👁 Xem đáp án</button></div></div></div>`;speedTmr=setInterval(()=>{tLeft--;const b=el('spBar');if(b)b.style.width=(tLeft/15*100)+'%';if(tLeft<=0){clearInterval(speedTmr);speedReveal()}},1000)}
function speedReveal(){clearInterval(speedTmr);if(S.speedShown)return;S.speedShown=true;const a=el('spAns');if(a)a.style.display='block';const b=el('spBtns');if(b)b.innerHTML='<button class="fc-speed-bad" onclick="speedMark(false)">❌ Chưa nhớ</button><button class="fc-speed-ok" onclick="speedMark(true)">✅ Đã nhớ</button>'}
function speedMark(ok){const card=S.cards[S.idx];if(ok){S.score++;sfxOk()}else sfxWrong();S.log.push({q:card.q,a:card.a,correct:ok});S.idx++;renderSpeed()}

function renderResult(){clearInterval(speedTmr);sfxWin();const tot=S.total;const pct=Math.round(S.score/tot*100);let trophy='🥉',rank='Cần ôn thêm';if(pct>=90){trophy='🏆';rank='Xuất sắc ⭐⭐⭐'}else if(pct>=70){trophy='🥇';rank='Tốt ⭐⭐'}else if(pct>=50){trophy='🥈';rank='Khá ⭐'}const correct=S.log.filter(r=>r.correct).length;const rows=S.log.slice(0,8).map(r=>`<div class="fc-review-row ${r.correct?'rr-ok':'rr-bad'}"><span>${r.correct?'✅':'❌'}</span><span class="fc-review-row-q">${esc(r.q.slice(0,50))}${r.q.length>50?'…':''}</span><span class="fc-review-row-a">${esc(r.a.slice(0,35))}${r.a.length>35?'…':''}</span></div>`).join('');app.innerHTML=`<div class="fc-result"><span class="fc-result-trophy">${trophy}</span><div class="fc-result-score">${pct}%</div><div class="fc-result-fraction">${S.score}/${tot} câu đúng</div><div class="fc-result-rank">${rank}</div><div class="fc-result-grid"><div class="fc-res-stat"><span class="fc-res-val">${correct}</span><span class="fc-res-lbl">Đúng</span></div><div class="fc-res-stat"><span class="fc-res-val">${tot-correct}</span><span class="fc-res-lbl">Sai</span></div><div class="fc-res-stat"><span class="fc-res-val">${pct}%</span><span class="fc-res-lbl">Tỉ lệ</span></div></div><div class="fc-result-deck-review"><h4>Xem lại ${Math.min(8,S.log.length)} câu</h4>${rows}${S.log.length>8?'<div style="text-align:center;font-size:.78rem;color:#9ca3af;margin-top:6px">...và '+(S.log.length-8)+' câu nữa</div>':''}</div><div class="fc-result-actions"><button class="fc-btn-primary" onclick="startStudy(S.mode)">🔄 Học lại</button><button class="fc-btn-secondary" onclick="renderModeSelect()">Đổi chế độ</button><button class="fc-btn-secondary" onclick="renderHome()">← Bộ thẻ khác</button></div></div>`}

function showToast(msg){let w=document.getElementById('vsToasts');if(!w){w=document.createElement('div');w.id='vsToasts';document.body.appendChild(w)}const t=document.createElement('div');t.className='vs-toast';t.textContent=msg;w.appendChild(t);requestAnimationFrame(()=>t.classList.add('toast-show'));setTimeout(()=>{t.classList.remove('toast-show');setTimeout(()=>t.remove(),350)},3000)}
renderHome();
</script>
</body>
</html>