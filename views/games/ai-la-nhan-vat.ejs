// ── Game state ────────────────────────────────────────────
let state = {
  phase: 'splash',   // splash | playing | result
  order: [],         // shuffled CHARS indices
  round: 0,          // current round index (0-9)
  clueShown: 0,      // 1,2,3
  answered: false,
  correct: false,
  score: 0,
  rounds: [],        // {name, correct, cluesUsed, points}
  timerVal: 20,
  timerMax: 20,
  timerInterval: null,
};

// ── Audio ─────────────────────────────────────────────────
let AC;
function beep(f,d,v=.2,t='sine',delay=0){
  if(!AC)try{AC=new(window.AudioContext||window.webkitAudioContext)();}catch(e){return;}
  const o=AC.createOscillator(),g=AC.createGain();
  o.connect(g);g.connect(AC.destination);
  o.type=t;o.frequency.value=f;
  g.gain.setValueAtTime(v,AC.currentTime+delay);
  g.gain.exponentialRampToValueAtTime(.001,AC.currentTime+delay+d);
  o.start(AC.currentTime+delay);o.stop(AC.currentTime+delay+d+.01);
}
function sfxCorrect(){ beep(440,.1,.2,'sine');beep(550,.1,.2,'sine',.1);beep(660,.2,.2,'sine',.2); }
function sfxWrong()  { beep(220,.3,.2,'sawtooth'); }
function sfxClick()  { beep(600,.05,.1,'sine'); }
function sfxReveal() { beep(330,.08,.12,'sine'); }
function sfxWin()    {
  [523,659,784,1047,784,1047].forEach((f,i)=>beep(f,.15,.2,'sine',i*.12));
}

// ── Utilities ─────────────────────────────────────────────
function shuffle(arr){ const a=[...arr];for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a; }
function el(id){ return document.getElementById(id); }
const app = document.getElementById('alnvApp');

// ── RENDER: Splash ────────────────────────────────────────
function renderSplash(){
  stopTimer();
  const previews = CHARS.map(c=>`<div class="alnv-char-preview-item" title="${c.name}">${c.emoji}</div>`).join('');
  app.innerHTML = `
  <div class="alnv-splash">
    <span class="alnv-splash-icon">🕵️</span>
    <h1>Ai là nhân vật?</h1>
    <p>Đọc từng gợi ý và đoán tên anh hùng lịch sử Việt Nam.<br>Đoán càng sớm, điểm càng cao!</p>
    <div class="alnv-char-preview">${previews}</div>
    <button class="btn-start-game" onclick="startGame()">
      Bắt đầu ngay <span class="arrow">→</span>
    </button>
  </div>`;
}

// ── Start game ────────────────────────────────────────────
function startGame(){
  sfxClick();
  try{ if(!AC)AC=new(window.AudioContext||window.webkitAudioContext)(); }catch(e){}
  state.order = shuffle(CHARS.map((_,i)=>i));
  state.round  = 0;
  state.score  = 0;
  state.rounds = [];
  state.phase  = 'playing';
  renderRound();
}

// ── RENDER: Round ─────────────────────────────────────────
function renderRound(){
  stopTimer();
  const ci   = state.order[state.round];
  const char = CHARS[ci];
  state.clueShown = 1;
  state.answered  = false;
  state.correct   = false;
  state.timerVal  = state.timerMax;

  // Build wrong options pool + correct mixed
  const opts = shuffle([char.name, ...char.wrong.slice(0,3)]);
  const letters = ['A','B','C','D'];

  // Clue rows (all 3, locked/visible)
  const clueHTML = char.clues.map((c,i)=>`
    <div class="alnv-clue ${i===0?'visible active-clue':'locked'}" id="clue${i}">
      <div class="alnv-clue-num">${i+1}</div>
      <div class="alnv-clue-text">${i===0?c:'<em>Gợi ý '+(i+1)+' — chưa mở khóa...</em>'}</div>
    </div>`).join('');

  const optsHTML = opts.map((o,i)=>`
    <button class="alnv-opt" id="opt${i}" onclick="answer('${o.replace(/'/g,"\\'")}',this)">
      <span class="opt-letter">${letters[i]}</span>
      ${o}
    </button>`).join('');

  const pct = (state.round / CHARS.length) * 100;

  app.innerHTML = `
  <!-- HUD -->
  <div class="alnv-hud">
    <div class="hud-item">
      <span class="hud-value" id="hudScore">${state.score}</span>
      <span class="hud-label">Điểm</span>
    </div>
    <div class="hud-item">
      <span class="hud-value">${state.round+1}/${CHARS.length}</span>
      <span class="hud-label">Câu</span>
    </div>
    <div class="hud-progress">
      <div class="hud-label" style="margin-bottom:2px">Tiến độ</div>
      <div class="hud-prog-bar"><div class="hud-prog-fill" style="width:${pct}%"></div></div>
    </div>
    <div class="hud-item">
      <div class="hud-timer-ring" id="timerRing">
        <svg width="52" height="52" viewBox="0 0 52 52">
          <circle cx="26" cy="26" r="22" fill="none" stroke="#f2f4f7" stroke-width="4"/>
          <circle id="timerCircle" cx="26" cy="26" r="22" fill="none" stroke="#ff7a1a"
            stroke-width="4" stroke-dasharray="${2*Math.PI*22}"
            stroke-dashoffset="0" stroke-linecap="round"/>
        </svg>
        <div class="hud-timer-val" id="timerVal">${state.timerVal}</div>
      </div>
    </div>
  </div>

  <!-- Card -->
  <div class="alnv-card" id="alnvCard">
    <div class="alnv-card-top">
      <div class="alnv-avatar" id="charAvatar">${char.emoji}</div>
      <div class="alnv-card-header">
        <div class="alnv-round-badge">Câu ${state.round+1} / ${CHARS.length}</div>
        <div class="alnv-question-title">Đây là nhân vật lịch sử nào?</div>
        <div class="alnv-clue-counter">Đang hiện: <span id="clueCount">1</span>/3 gợi ý</div>
      </div>
    </div>
    <div class="alnv-clues">${clueHTML}</div>
    <div class="alnv-options">
      <div class="alnv-options-label">Chọn câu trả lời của bạn:</div>
      <div class="alnv-opts-grid">${optsHTML}</div>
    </div>
    <div class="alnv-action" id="alnvAction">
      <div class="alnv-feedback" id="alnvFeedback" style="visibility:hidden">–</div>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn-reveal" id="btnReveal" onclick="revealNext()">💡 Gợi ý tiếp theo</button>
        <button class="btn-next-q btn-disabled" id="btnNext" onclick="nextQuestion()">Câu tiếp →</button>
      </div>
    </div>
  </div>`;

  startTimer(char.name);
}

// ── Timer ─────────────────────────────────────────────────
function startTimer(correctName){
  const totalLen = 2 * Math.PI * 22;
  state.timerVal = state.timerMax;
  state.timerInterval = setInterval(()=>{
    if(state.answered){ stopTimer(); return; }
    state.timerVal--;
    const valEl  = el('timerVal');
    const circle = el('timerCircle');
    const ring   = el('timerRing');
    if(!valEl) return stopTimer();
    valEl.textContent = state.timerVal;
    const pct = state.timerVal / state.timerMax;
    circle.setAttribute('stroke-dashoffset', totalLen*(1-pct));
    circle.setAttribute('stroke', state.timerVal<=5?'#e74c3c':'#ff7a1a');
    if(state.timerVal<=5) ring.classList.add('timer-urgent');
    if(state.timerVal<=0){
      stopTimer();
      if(!state.answered) timeOut(correctName);
    }
  },1000);
}
function stopTimer(){ clearInterval(state.timerInterval); }
function timeOut(correctName){
  state.answered=true;
  state.rounds.push({name:correctName,correct:false,cluesUsed:state.clueShown,points:0});
  const fb=el('alnvFeedback');
  if(fb){ fb.className='alnv-feedback wrong-fb';fb.style.visibility='visible';fb.textContent='⏰ Hết giờ! Đáp án: '+correctName; }
  document.querySelectorAll('.alnv-opt').forEach(b=>{b.disabled=true;if(b.textContent.trim()===correctName)b.classList.add('correct');});
  const avatar=el('charAvatar');if(avatar)avatar.classList.add('wrong-reveal');
  el('btnNext')?.classList.remove('btn-disabled');
  el('btnReveal')?.classList.add('btn-disabled');
  sfxWrong();
}

// ── Answer ────────────────────────────────────────────────
function answer(chosen, btn){
  if(state.answered) return;
  sfxClick();
  stopTimer();
  state.answered = true;
  const ci   = state.order[state.round];
  const char = CHARS[ci];
  const isOk = chosen === char.name;
  state.correct = isOk;

  // Points: 3 for clue 1, 2 for clue 2, 1 for clue 3, 0 wrong
  const pts = isOk ? Math.max(1, 4 - state.clueShown) : 0;
  state.score += pts;
  state.rounds.push({name:char.name,correct:isOk,cluesUsed:state.clueShown,points:pts});

  // Style buttons
  document.querySelectorAll('.alnv-opt').forEach(b=>{
    b.disabled=true;
    if(b.textContent.trim()===char.name) b.classList.add('correct');
  });
  if(!isOk) btn.classList.add('wrong');

  // Feedback
  const fb = el('alnvFeedback');
  if(isOk){
    fb.className='alnv-feedback correct-fb';
    fb.textContent=`✅ Chính xác! +${pts} điểm 🎉`;
    el('charAvatar')?.classList.add('revealed');
    sfxCorrect();
  } else {
    fb.className='alnv-feedback wrong-fb';
    fb.textContent=`❌ Sai rồi. Đúng là: ${char.name}`;
    el('charAvatar')?.classList.add('wrong-reveal');
    sfxWrong();
  }
  fb.style.visibility='visible';

  // Update HUD score
  const hs=el('hudScore'); if(hs) hs.textContent=state.score;

  // Reveal all remaining clues
  char.clues.forEach((_,i)=>{
    const cEl=el('clue'+i);
    if(cEl&&cEl.classList.contains('locked')){
      cEl.classList.remove('locked');
      cEl.querySelector('.alnv-clue-text').textContent=char.clues[i];
      setTimeout(()=>cEl.classList.add('visible'),i*150);
    }
    cEl?.classList.remove('active-clue');
  });

  el('btnNext')?.classList.remove('btn-disabled');
  el('btnReveal')?.classList.add('btn-disabled');
}

// ── Reveal next clue ──────────────────────────────────────
function revealNext(){
  if(state.answered || state.clueShown>=3) return;
  sfxReveal();
  state.clueShown++;
  el('clueCount').textContent=state.clueShown;

  const ci   = state.order[state.round];
  const char = CHARS[ci];
  const idx  = state.clueShown-1;
  const cEl  = el('clue'+idx);
  if(cEl){
    cEl.classList.remove('locked');
    cEl.querySelector('.alnv-clue-text').textContent=char.clues[idx];
    setTimeout(()=>{
      cEl.classList.add('visible','active-clue');
      // remove active from previous
      if(idx>0) el('clue'+(idx-1))?.classList.remove('active-clue');
    },50);
  }
  if(state.clueShown>=3) el('btnReveal')?.classList.add('btn-disabled');
}

// ── Next question ─────────────────────────────────────────
function nextQuestion(){
  sfxClick();
  state.round++;
  if(state.round>=CHARS.length) renderResult();
  else renderRound();
}

// ── RENDER: Result ────────────────────────────────────────
function renderResult(){
  stopTimer();
  state.phase='result';
  sfxWin();

  const maxScore = CHARS.length * 3;
  const pct = state.score / maxScore;
  let trophy='🥉', rank='Cần ôn luyện thêm 📚';
  if(pct>=0.9){trophy='🏆';rank='Sử gia xuất sắc ⭐⭐⭐';}
  else if(pct>=0.67){trophy='🥇';rank='Học giả lịch sử ⭐⭐';}
  else if(pct>=0.33){trophy='🥈';rank='Người yêu sử ⭐';}

  const correct=state.rounds.filter(r=>r.correct).length;
  const avgClues=(state.rounds.reduce((s,r)=>s+r.cluesUsed,0)/state.rounds.length).toFixed(1);

  const rowsHTML = state.rounds.map((r,i)=>`
    <div class="round-row ${r.correct?'row-ok':'row-bad'}">
      <span class="round-row-icon">${r.correct?'✅':'❌'}</span>
      <span class="round-row-name">${CHARS[state.order[i]].emoji} ${r.name}</span>
      <span class="round-row-pts">${r.correct?'+'+r.points+' điểm':'0 điểm'}</span>
    </div>`).join('');

  app.innerHTML=`
  <div class="alnv-result">
    <span class="alnv-result-trophy">${trophy}</span>
    <div class="alnv-result-score">${state.score}</div>
    <div class="alnv-result-max">/ ${maxScore} điểm</div>
    <div class="alnv-result-rank">${rank}</div>

    <div class="alnv-result-breakdown">
      <div class="result-stat">
        <span class="result-stat-val">${correct}</span>
        <span class="result-stat-lbl">Trả lời đúng</span>
      </div>
      <div class="result-stat">
        <span class="result-stat-val">${CHARS.length-correct}</span>
        <span class="result-stat-lbl">Trả lời sai</span>
      </div>
      <div class="result-stat">
        <span class="result-stat-val">${avgClues}</span>
        <span class="result-stat-lbl">Gợi ý TB</span>
      </div>
    </div>

    <div class="alnv-rounds-list">
      <h4>Chi tiết từng câu</h4>
      ${rowsHTML}
    </div>

    <div class="alnv-result-actions">
      <button class="btn-play-again" onclick="startGame()">🔄 Chơi lại</button>
      <a href="/#games" class="btn-back-home">← Danh sách game</a>
    </div>
  </div>`;
}

// ── Init ──────────────────────────────────────────────────
renderSplash();
</script>

</body>
</html>
