// ── LEVEL 3 — Cắm cờ ─────────────────────────────────────
const WORLD_W=3200;
const OBS3=[{wx:380,w:32,h:28},{wx:640,w:36,h:30},{wx:900,w:28,h:32},{wx:1150,w:34,h:28},{wx:1400,w:30,h:32},{wx:1620,w:36,h:28},{wx:1850,w:32,h:30},{wx:2100,w:34,h:28},{wx:2350,w:30,h:32},{wx:2580,w:36,h:28},{wx:2780,w:32,h:30}];
const COINS3=[300,550,800,1050,1300,1550,1800,2050,2300,2560];
const L3={wx:80,wy:0,vx:160,vy:0,onGround:false,camX:0,win:false,planted:false,plantTimer:0,jumpCount:0,animFrame:0,hp:3,coins:[],shakeX:0,shakeTimer:0,flashTimer:0};
function getGroundY3(wx){return H-90-(wx/WORLD_W)*140+Math.sin(wx/200)*18+Math.sin(wx/80)*8;}
function initLevel3(){
  Object.assign(L3,{wx:80,wy:getGroundY3(80)-60,vx:160,vy:0,onGround:false,camX:0,win:false,planted:false,jumpCount:0,animFrame:0,hp:3,coins:COINS3.map(cx=>({wx:cx,collected:false})),shakeX:0,shakeTimer:0,flashTimer:0});
  STATE='level3';mAct.style.visibility='visible';mAct.textContent='⬆️ NHẢY';mLeft.style.display='none';mRight.style.display='none';mUp.style.display='';mDown.style.display='none';
}
function updateLevel3(dt){
  if(L3.win)return;L3.animFrame++;
  if((justPressed['Space']||justPressed['ArrowUp']||justPressed['KeyW'])&&(L3.onGround||L3.jumpCount<2)){L3.vy=-440;L3.onGround=false;L3.jumpCount++;sfxJump();}
  L3.vy+=820*dt;L3.wx+=L3.vx*dt;L3.wy+=L3.vy*dt;
  const gy=getGroundY3(L3.wx);
  if(L3.wy>=gy-60){L3.wy=gy-60;L3.vy=0;L3.onGround=true;L3.jumpCount=0;}else L3.onGround=false;
  L3.camX=Math.max(0,Math.min(WORLD_W-W,L3.wx-220));
  for(const ob of OBS3){const obGY=getGroundY3(ob.wx),px=L3.wx-L3.camX,py=L3.wy,obX=ob.wx-L3.camX,obY=obGY-ob.h;if(Math.abs(px-obX-ob.w/2)<ob.w/2+16&&py+60>obY&&py+40<obGY){L3.hp--;sfxHit();L3.shakeX=8;L3.shakeTimer=.3;L3.flashTimer=.25;L3.wx=ob.wx-80;L3.wy=getGroundY3(L3.wx)-60;L3.vy=0;if(L3.hp<=0)L3.hp=0;break;}}
  for(const c of L3.coins){if(!c.collected&&Math.abs(L3.wx-c.wx)<36){c.collected=true;score+=10;sfxCoin();}}
  if(L3.shakeTimer>0){L3.shakeTimer-=dt;L3.shakeX=L3.shakeTimer>0?Math.sin(L3.shakeTimer*35)*7:0;}
  if(L3.flashTimer>0)L3.flashTimer-=dt;
  if(L3.wx>=WORLD_W-150&&!L3.win){L3.win=true;L3.planted=true;sfxVictory();score+=100;setTimeout(()=>{STATE='victory';hitZones=[];},3500);}
}
function drawLevel3(){
  ctx.save();ctx.translate(L3.shakeX,0);
  const cam=L3.camX,prog=L3.wx/WORLD_W;
  const r=Math.round(26+prog*180),g=Math.round(48+prog*100),b=Math.round(110-prog*70);
  drawSky(`rgb(${r},${g},${b})`,'#ffd580');
  ctx.save();ctx.translate(-cam*.15,0);drawMountains(0,'rgba(80,120,60,0.6)',7,H*.58,100);ctx.restore();
  ctx.save();ctx.translate(-cam*.3,0);drawMountains(0,'rgba(50,90,40,0.7)',6,H*.65,80);ctx.restore();
  for(let wx=Math.floor(cam/40)*40;wx<cam+W+40;wx+=40){const sy=getGroundY3(wx),sx=wx-cam;const gg=ctx.createLinearGradient(sx,sy,sx,H);gg.addColorStop(0,'#5a8a30');gg.addColorStop(.08,'#4a7a20');gg.addColorStop(.15,'#6b4226');gg.addColorStop(1,'#3a2010');ctx.fillStyle=gg;ctx.fillRect(sx,sy,40,H-sy);}
  for(const ob of OBS3){const sx=ob.wx-cam;if(sx<-50||sx>W+50)continue;const obGY=getGroundY3(ob.wx),obY=obGY-ob.h;ctx.fillStyle='#7a6030';roundRect(sx-ob.w/2,obY,ob.w,ob.h,5);ctx.fill();ctx.fillStyle='#9a8050';roundRect(sx-ob.w/2+2,obY+2,ob.w-4,ob.h/2,4);ctx.fill();ctx.strokeStyle='#5a4020';ctx.lineWidth=1.5;for(let s=0;s<3;s++){ctx.beginPath();ctx.moveTo(sx-ob.w/2+4,obY+6+s*8);ctx.lineTo(sx+ob.w/2-4,obY+6+s*8);ctx.stroke();}}
  for(const c of L3.coins){if(c.collected)continue;const sx=c.wx-cam;if(sx<-20||sx>W+20)continue;const cy=getGroundY3(c.wx)-80-Math.sin(L3.animFrame*.08+c.wx)*6;ctx.fillStyle='#f5d020';star5(sx,cy,12,5);ctx.fill();ctx.strokeStyle='#c9a22a';ctx.lineWidth=1.5;ctx.stroke();}
  const fpX=WORLD_W-120-cam;if(fpX>-30&&fpX<W+30){const fpGY=getGroundY3(WORLD_W-120);ctx.fillStyle='#888';ctx.fillRect(fpX-3,fpGY-160,6,160);if(L3.planted){drawFlag(fpX+3,fpGY-160,60,40,L3.animFrame*.08);const gl=Math.sin(L3.animFrame*.1)*.3+.7;ctx.fillStyle=`rgba(255,220,0,${gl*.25})`;ctx.beginPath();ctx.arc(fpX+30,fpGY-140,60,0,Math.PI*2);ctx.fill();}else drawFlag(fpX+3,fpGY-120,60,40,0);}
  const px=L3.wx-cam,py=L3.wy,gy=getGroundY3(L3.wx);
  ctx.fillStyle='rgba(0,0,0,0.25)';ctx.beginPath();ctx.ellipse(px,(gy+py)/2+24,16*(1-(gy-py-60)/120),5,0,0,Math.PI*2);ctx.fill();
  drawSoldier(px,py+60,1,L3.animFrame,'walk');
  if(L3.flashTimer>0){ctx.fillStyle=`rgba(255,80,30,${L3.flashTimer*.6})`;ctx.fillRect(0,0,W,H);}
  ctx.fillStyle='rgba(0,0,0,0.55)';roundRect(6,6,W-12,50,10);ctx.fill();
  ctx.fillStyle='#f5e06a';ctx.font='bold 13px sans-serif';ctx.textAlign='left';ctx.fillText('❤️',12,30);for(let i=0;i<3;i++)drawHeart(42+i*28,10,i<L3.hp);
  drawProgressBar(180,14,330,26,Math.min(L3.wx/WORLD_W,1),'Tiến về mục tiêu');
  ctx.fillStyle='#f5e06a';ctx.font='bold 16px sans-serif';ctx.textAlign='right';ctx.fillText('⭐ '+score,W-14,32);
  ctx.fillStyle='rgba(0,0,0,0.6)';roundRect(W/2-160,H-36,320,30,8);ctx.fill();ctx.fillStyle='#f5e06a';ctx.font='bold 14px sans-serif';ctx.textAlign='center';ctx.fillText('🚩 CẤP 3 — Cắm cờ chiến thắng lên đỉnh đồi!',W/2,H-16);
  if(L3.wx<300){ctx.fillStyle='rgba(0,0,0,0.6)';roundRect(W/2-180,H/2-16,360,34,8);ctx.fill();ctx.fillStyle='#f5e06a';ctx.font='bold 15px sans-serif';ctx.textAlign='center';ctx.fillText('Nhấn SPACE / nút NHẢY để vượt chướng ngại!',W/2,H/2+7);}
  if(L3.win)drawWinOverlay('🚩 Cờ đã được cắm! Chiến thắng Điện Biên Phủ! 🎉');
  ctx.restore();
}

