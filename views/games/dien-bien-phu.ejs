];
const QUIZ2=[
  {q:'Chiến dịch Điện Biên Phủ kéo dài bao nhiêu ngày đêm?',opts:['45 ngày','50 ngày','56 ngày','60 ngày'],ans:2,fact:'56 ngày đêm chiến đấu anh dũng (13/3 đến 7/5/1954)!'},
  {q:'Chiến thuật đặc biệt nào quân ta dùng ở Điện Biên Phủ?',opts:['Đánh nhanh thắng nhanh','Đào chiến hào bao vây','Tấn công từ trên không','Đánh du kích trên núi'],ans:1,fact:'Quân ta đào hàng trăm km chiến hào để bao vây tiêu diệt địch!'},
  {q:'Sau chiến thắng Điện Biên Phủ, Pháp ký Hiệp định gì?',opts:['Hiệp định Paris','Hiệp định Genève','Hiệp định Vienna','Hiệp định La Haye'],ans:1,fact:'Pháp ký Hiệp định Genève (7/1954), rút khỏi Đông Dương!'},
];
let QZ={data:null,idx:0,answered:false,chosen:-1,feedback:'',nextCb:null};
function initQuiz(data,nextCb){QZ.data=data;QZ.idx=0;QZ.answered=false;QZ.chosen=-1;QZ.feedback='';QZ.nextCb=nextCb;buildQuizZones();}
function buildQuizZones(){
  hitZones=[];
  if(QZ.idx>=QZ.data.length){hitZones.push({x:W/2-90,y:H-80,w:180,h:44,fn:()=>{if(QZ.nextCb)QZ.nextCb();}});return;}
  const q=QZ.data[QZ.idx];
  if(!QZ.answered){
    const bx=[80,W/2+20],by=[230,310];
    q.opts.forEach((o,i)=>{const x=bx[i%2],y=by[Math.floor(i/2)];hitZones.push({x,y,w:300,h:58,fn:()=>{if(!QZ.answered){QZ.answered=true;QZ.chosen=i;QZ.feedback=q.fact;if(i===q.ans){score+=50;sfxCorrect();}else sfxWrong();buildQuizZones();}}});});
  }else{hitZones.push({x:W/2-90,y:H-80,w:180,h:44,fn:()=>{QZ.idx++;QZ.answered=false;QZ.chosen=-1;QZ.feedback='';buildQuizZones();}});}
}
function drawQuiz(){
  drawSky('#1a3060','#3a7aaa');drawMountains(0,'#2a5a2a',5,H*.7,80);drawGround(H*.7);
  ctx.fillStyle='rgba(5,20,5,0.82)';ctx.fillRect(0,0,W,H);
  if(QZ.idx>=QZ.data.length){
    drawPanel(W/2-220,80,440,300,'🎉 Hoàn thành bài trắc nghiệm!');
    ctx.fillStyle='#f5e06a';ctx.font='bold 22px sans-serif';ctx.textAlign='center';ctx.fillText(`Điểm của bạn: ⭐ ${score}`,W/2,190);
    ctx.fillStyle='#aaffaa';ctx.font='17px sans-serif';ctx.fillText('Làm tốt lắm! Tiếp tục hành trình nào!',W/2,230);
    drawButton(W/2-90,H-80,180,44,'▶ Tiếp tục');return;
  }
  const q=QZ.data[QZ.idx];
  drawPanel(60,50,W-120,H-70,'');
  ctx.fillStyle='#c9a22a';ctx.font='bold 13px sans-serif';ctx.textAlign='center';ctx.fillText(`📝 TRẮC NGHIỆM — Câu ${QZ.idx+1}/${QZ.data.length}`,W/2,85);
  ctx.strokeStyle='rgba(201,162,42,0.4)';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(80,94);ctx.lineTo(W-80,94);ctx.stroke();
  ctx.fillStyle='#fff';ctx.font='bold 18px sans-serif';ctx.textAlign='center';
  const words=q.q.split(' '),lines=[],maxW=W-180;let line='';
  for(const w of words){const test=line?line+' '+w:w;if(ctx.measureText(test).width>maxW&&line){lines.push(line);line=w;}else line=test;}if(line)lines.push(line);
  lines.forEach((l,i)=>ctx.fillText(l,W/2,130+i*26));
  if(!QZ.answered){
    const bx=[80,W/2+20],by=[230,310];
    q.opts.forEach((opt,i)=>{const x=bx[i%2],y=by[Math.floor(i/2)];drawButton(x,y,300,58,['A','B','C','D'][i]+'. '+opt,false,'#2a5a3a');});
  }else{
    const bx=[80,W/2+20],by=[220,300];
    q.opts.forEach((opt,i)=>{const x=bx[i%2],y=by[Math.floor(i/2)];let col='#2a3a5a';if(i===q.ans)col='#1a6a1a';else if(i===QZ.chosen&&QZ.chosen!==q.ans)col='#6a1a1a';fillRR(x,y,300,54,10,col);ctx.fillStyle=i===q.ans?'#aaffaa':i===QZ.chosen?'#ffaaaa':'#888';ctx.font='bold 15px sans-serif';ctx.textAlign='center';ctx.fillText((['A','B','C','D'][i]+'. '+opt).substring(0,32),x+150,y+31);if(i===q.ans){ctx.fillStyle='#aaffaa';ctx.textAlign='left';ctx.fillText('✓',x+6,y+33);}});
    if(QZ.chosen===q.ans){fillRR(80,H-130,W-160,38,8,'rgba(20,100,20,0.7)');ctx.fillStyle='#aaffaa';ctx.font='14px sans-serif';ctx.textAlign='center';ctx.fillText('✅ Chính xác! '+QZ.feedback.substring(0,55),W/2,H-106);}
    else{fillRR(80,H-130,W-160,38,8,'rgba(100,20,20,0.7)');ctx.fillStyle='#ffaaaa';ctx.font='14px sans-serif';ctx.textAlign='center';ctx.fillText('❌ Chưa đúng! '+QZ.feedback.substring(0,55),W/2,H-106);}
    drawButton(W/2-90,H-80,180,42,'Câu tiếp theo →');
  }
  ctx.fillStyle='#f5e06a';ctx.font='bold 14px sans-serif';ctx.textAlign='right';ctx.fillText('⭐ '+score,W-70,60);
}

// ── Overlays ──────────────────────────────────────────────
function drawWinOverlay(msg){
  ctx.fillStyle='rgba(0,40,0,0.75)';ctx.fillRect(0,0,W,H);
  ctx.fillStyle='#f5e06a';ctx.font='bold 28px sans-serif';ctx.textAlign='center';ctx.fillText('🎉 '+msg,W/2,H/2+Math.sin(Date.now()*.003)*3);
  ctx.fillStyle='#aaffaa';ctx.font='16px sans-serif';ctx.fillText('Đang chuyển sang phần tiếp theo...',W/2,H/2+42);
}
function drawGameOver(retryFn){
  ctx.fillStyle='rgba(60,0,0,0.8)';ctx.fillRect(0,0,W,H);
  drawPanel(W/2-200,H/2-110,400,220,'💔 Thử lại nào!');
  ctx.fillStyle='#ffaaaa';ctx.font='18px sans-serif';ctx.textAlign='center';ctx.fillText('Bạn đã bị trúng đá quá nhiều lần.',W/2,H/2-20);
  ctx.fillStyle='#f5e06a';ctx.font='16px sans-serif';ctx.fillText('Đừng nản lòng — hãy thử lại!',W/2,H/2+12);
  drawButton(W/2-90,H/2+50,180,44,'🔄 Thử lại');
  hitZones=[{x:W/2-90,y:H/2+50,w:180,h:44,fn:()=>retryFn()}];
}

// ── SPLASH ────────────────────────────────────────────────
let splashFrame=0;
const SPLASH_S=[{x:120,y:0},{x:220,y:0},{x:670,y:0},{x:590,y:0}];
function drawSplash(){
  splashFrame++;const t=splashFrame;
  drawSky('#0a1a30','#1a3a6a');drawMountains(0,'#1a3a1a',5,H*.65,100);drawMountains(0,'#0a2a0a',4,H*.75,80);drawGround(H*.75);
  for(let i=0;i<30;i++){const a=0.4+0.4*Math.sin(t*.03+i);ctx.fillStyle=`rgba(255,255,200,${a})`;ctx.beginPath();ctx.arc((i*137)%W,(i*89)%200,1.2,0,Math.PI*2);ctx.fill();}
  drawCloud(80+Math.sin(t*.005)*20,60,.7);drawCloud(600+Math.sin(t*.004)*15,80,.9);drawCloud(350+Math.sin(t*.006)*18,40,.5);
  const gy=H*.75;for(const s of SPLASH_S){s.x=(s.x+.8)%(W+60)-30;drawSoldier(s.x,gy,1,t,'walk');}
  ctx.save();ctx.globalAlpha=.12;drawFlag(W/2-160,80,320,200,t*.04);ctx.globalAlpha=1;ctx.restore();
  const by=2+Math.sin(t*.02)*3;
  ctx.save();ctx.shadowColor='rgba(201,162,42,0.5)';ctx.shadowBlur=30;ctx.fillStyle='rgba(5,20,5,0.88)';roundRect(W/2-310,80+by,620,160,18);ctx.fill();ctx.shadowBlur=0;ctx.restore();
  strokeRR(W/2-310,80+by,620,160,18,'#c9a22a',2);strokeRR(W/2-302,88+by,604,144,14,'rgba(201,162,42,0.35)',1);
  drawFlag(W/2-282,100+by,60,40,t*.04);drawFlag(W/2+222,100+by,60,40,t*.04);
  ctx.textAlign='center';ctx.fillStyle='#f5e06a';ctx.font='bold 13px sans-serif';ctx.fillText('🎮 TRÒ CHƠI LỊCH SỬ GIÁO DỤC — VIỆT SỬ QUEST',W/2,115+by);
  ctx.font='bold 46px sans-serif';ctx.fillStyle='#ff4444';ctx.shadowColor='rgba(255,100,0,0.5)';ctx.shadowBlur=15;ctx.fillText('ĐIỆN BIÊN PHỦ',W/2,162+by);ctx.shadowBlur=0;
  ctx.font='bold 32px sans-serif';ctx.fillStyle='#f5e06a';ctx.fillText('⚔  1954  ⚔',W/2,198+by);
  ctx.font='15px sans-serif';ctx.fillStyle='#88ccaa';ctx.fillText('Trò chơi dành cho học sinh lớp 6 – 9',W/2,226+by);
  drawCannon(W/2-60,H*.75-18,t*.02);
  const bp=.04+.02*Math.sin(t*.06);ctx.save();ctx.translate(W/2,330);ctx.scale(1+bp,1+bp);drawButton(-110,-28,220,56,'▶ BẮT ĐẦU CUỘC HÀNH TRÌNH',false,'#e74c3c');ctx.restore();
  ctx.fillStyle='rgba(200,220,200,0.7)';ctx.font='13px sans-serif';ctx.textAlign='center';ctx.fillText('3 cấp độ · 6 câu hỏi lịch sử · Hệ thống điểm',W/2,400);
  hitZones=[{x:W/2-130,y:300,w:260,h:60,fn:()=>{initAudio();initLevel1();}}];
}

// ── VICTORY ───────────────────────────────────────────────
let victoryFrame=0;const CONF=[];
function initConf(){CONF.length=0;for(let i=0;i<80;i++)CONF.push({x:Math.random()*W,y:-20-Math.random()*200,vx:(Math.random()-.5)*3,vy:1.5+Math.random()*3,r:4+Math.random()*6,color:['#f5d020','#e74c3c','#2ecc71','#3498db','#e91e63','#ff9800'][Math.floor(Math.random()*6)],rot:Math.random()*Math.PI,vrot:(Math.random()-.5)*.2});}
function drawVictory(){
  if(victoryFrame===0)initConf();victoryFrame++;const t=victoryFrame;
  drawSky('#ff8c42','#ffcc88');drawMountains(0,'#2a5a2a',5,H*.65,100);drawGround(H*.65);
  ctx.fillStyle='#888';ctx.fillRect(W/2-3,H*.2,6,H*.45);drawFlag(W/2+3,H*.2,90,60,t*.06);
  ctx.save();ctx.translate(W/2,H*.15);ctx.rotate(t*.005);for(let r=0;r<12;r++){const a=r*Math.PI/6;ctx.strokeStyle=`rgba(255,220,100,${.1+.05*Math.sin(r+t*.02)})`;ctx.lineWidth=20;ctx.beginPath();ctx.moveTo(0,0);ctx.lineTo(Math.cos(a)*250,Math.sin(a)*250);ctx.stroke();}ctx.restore();
  for(const c of CONF){c.x+=c.vx;c.y+=c.vy;c.rot+=c.vrot;if(c.y>H+20){c.y=-20;c.x=Math.random()*W;}ctx.save();ctx.translate(c.x,c.y);ctx.rotate(c.rot);ctx.fillStyle=c.color;ctx.fillRect(-c.r/2,-c.r/2,c.r,c.r/2);ctx.restore();}
  for(let i=0;i<5;i++)drawSoldier(80+i*150,H*.65,1,t+(i*20),'walk');
  const pw=600,ph=280;ctx.fillStyle='rgba(5,25,5,0.9)';roundRect((W-pw)/2,60,pw,ph,18);ctx.fill();strokeRR((W-pw)/2,60,pw,ph,18,'#f5d020',3);
  ctx.textAlign='center';ctx.fillStyle='#f5d020';ctx.font='bold 15px sans-serif';ctx.fillText('🏆 CHÚC MỪNG CHIẾN THẮNG! 🏆',W/2,98);ctx.strokeStyle='rgba(245,208,32,0.4)';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo((W-pw)/2+20,110);ctx.lineTo((W+pw)/2-20,110);ctx.stroke();
  ctx.fillStyle='#fff';ctx.font='bold 19px sans-serif';ctx.fillText('Bạn đã giúp quân đội Việt Nam',W/2,142);ctx.fillStyle='#ff6644';ctx.font='bold 22px sans-serif';ctx.fillText('giành Chiến thắng Điện Biên Phủ! 🇻🇳',W/2,174);
  ctx.fillStyle='#88ccaa';ctx.font='15px sans-serif';ctx.fillText(`Tổng điểm: ⭐ ${score}  ·  Hoàn thành 3 cấp độ`,W/2,210);
  ctx.fillStyle='rgba(200,240,200,0.8)';ctx.font='13px sans-serif';ctx.fillText('"Không có gì quý hơn độc lập, tự do." — Hồ Chí Minh',W/2,238);
  ctx.fillStyle='rgba(255,220,150,0.7)';ctx.font='12px sans-serif';ctx.fillText('📜 Chiến thắng Điện Biên Phủ 7/5/1954 kết thúc ách thực dân Pháp ở Đông Dương.',W/2,265);
  drawButton(W/2-100,H-72,200,46,'🔄 Chơi lại từ đầu');
  hitZones=[{x:W/2-100,y:H-72,w:200,h:46,fn:()=>{score=0;victoryFrame=0;STATE='splash';hitZones=[];document.getElementById('mCtrl').style.display='none';}}];
}

// ── MAIN LOOP ─────────────────────────────────────────────
let lastTime=0;
function loop(ts){
  const dt=Math.min((ts-lastTime)/1000,.08);lastTime=ts;
  ctx.clearRect(0,0,W,H);
  switch(STATE){
    case 'splash':  drawSplash();break;
    case 'level1':  updateLevel1(dt);drawLevel1();break;
    case 'level2':  updateLevel2(dt);drawLevel2();break;
    case 'level3':  updateLevel3(dt);drawLevel3();break;
    case 'quiz1':case'quiz2': drawQuiz();break;
    case 'victory': drawVictory();break;
  }
  for(const k in justPressed)delete justPressed[k];
  requestAnimationFrame(loop);
}
STATE='splash';
document.getElementById('mCtrl').style.display='none';
requestAnimationFrame(ts=>{lastTime=ts;loop(ts);});
</script>

</body>
