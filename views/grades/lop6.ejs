<!DOCTYPE html>
<html lang="vi">
<%- include('../partials/head') %>
<body>

<%- include('../partials/header', { brand }) %>

<style>
/* ── Page hero ── */
.lop6-hero {
  background: linear-gradient(135deg, #fff8f3 0%, #fff3ea 100%);
  border-bottom: 2px solid #ffe0c8;
  padding: 3rem 0 2.5rem;
}
.lop6-hero-inner {
  max-width: 1100px; margin: 0 auto; padding: 0 1.5rem;
  display: flex; align-items: center; gap: 2rem; flex-wrap: wrap;
}
.lop6-badge {
  background: #ff7a1a; color: #fff;
  font-size: .75rem; font-weight: 700; letter-spacing: .08em;
  padding: .25rem .75rem; border-radius: 99px; text-transform: uppercase;
  display: inline-block; margin-bottom: .75rem;
}
.lop6-hero h1 { font-size: 2.4rem; font-weight: 800; color: #1a1a1a; margin: 0 0 .5rem; line-height: 1.15; }
.lop6-hero h1 span { color: #ff7a1a; }
.lop6-hero p { color: #555; font-size: 1.05rem; margin: 0 0 1.25rem; max-width: 520px; }
.lop6-stats { display: flex; gap: 2rem; flex-wrap: wrap; }
.lop6-stat { text-align: center; }
.lop6-stat strong { display: block; font-size: 1.6rem; font-weight: 800; color: #ff7a1a; line-height: 1; }
.lop6-stat span { font-size: .8rem; color: #888; }

/* ── Main layout ── */
.lop6-main { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.5rem; display: grid; grid-template-columns: 280px 1fr; gap: 2rem; align-items: start; }
@media (max-width: 768px) { .lop6-main { grid-template-columns: 1fr; } }

/* ── Sidebar ── */
.lop6-sidebar { position: sticky; top: 80px; }
.sidebar-title { font-size: .7rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: #aaa; margin-bottom: .75rem; }
.chapter-nav { display: flex; flex-direction: column; gap: .35rem; }
.chapter-nav-item {
  display: flex; align-items: center; gap: .6rem;
  padding: .6rem .85rem; border-radius: 10px; cursor: pointer;
  border: 1.5px solid transparent; transition: all .18s;
  font-size: .88rem; font-weight: 500; color: #444;
  background: #fff;
}
.chapter-nav-item:hover { border-color: #ff7a1a22; background: #fff8f3; color: #ff7a1a; }
.chapter-nav-item.active { background: #ff7a1a; color: #fff; border-color: #ff7a1a; }
.chapter-nav-item .ch-icon { font-size: 1rem; }
.chapter-nav-item .ch-label { flex: 1; line-height: 1.3; }
.chapter-nav-item .ch-num { font-size: .72rem; opacity: .65; }

/* ── Content ── */
.lop6-content {}

/* Chapter section */
.chapter-section { display: none; }
.chapter-section.active { display: block; }

.chapter-header {
  background: #fff; border: 1.5px solid #f0e8e0;
  border-radius: 16px; padding: 1.5rem 1.75rem; margin-bottom: 1.5rem;
  display: flex; align-items: flex-start; gap: 1.25rem;
}
.chapter-icon-big {
  width: 56px; height: 56px; border-radius: 14px; background: #fff4ec;
  display: flex; align-items: center; justify-content: center; font-size: 1.75rem; flex-shrink: 0;
}
.chapter-header-text h2 { font-size: 1.35rem; font-weight: 800; color: #1a1a1a; margin: 0 0 .3rem; }
.chapter-header-text .ch-subtitle { font-size: .8rem; font-weight: 600; color: #ff7a1a; letter-spacing: .05em; text-transform: uppercase; margin-bottom: .4rem; }
.chapter-header-text p { color: #666; font-size: .9rem; margin: 0; line-height: 1.6; }

/* Lesson cards */
.lessons-grid { display: flex; flex-direction: column; gap: 1.25rem; }

.lesson-card {
  background: #fff; border: 1.5px solid #f0e8e0; border-radius: 14px;
  overflow: hidden; transition: box-shadow .2s, border-color .2s;
}
.lesson-card:hover { box-shadow: 0 4px 24px #ff7a1a18; border-color: #ffcba0; }

.lesson-header {
  display: flex; align-items: center; gap: 1rem;
  padding: 1.1rem 1.4rem; cursor: pointer; user-select: none;
}
.lesson-num {
  width: 36px; height: 36px; border-radius: 10px;
  background: #fff4ec; color: #ff7a1a; font-weight: 800; font-size: .88rem;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.lesson-title { flex: 1; font-size: .97rem; font-weight: 600; color: #1a1a1a; line-height: 1.4; }
.lesson-toggle {
  width: 28px; height: 28px; border-radius: 8px; background: #f5f0eb;
  display: flex; align-items: center; justify-content: center;
  font-size: .85rem; color: #aaa; transition: transform .25s, background .2s;
  flex-shrink: 0;
}
.lesson-card.open .lesson-toggle { transform: rotate(180deg); background: #ff7a1a; color: #fff; }

.lesson-body {
  display: none; padding: 0 1.4rem 1.4rem; border-top: 1px solid #f5ede5;
}
.lesson-card.open .lesson-body { display: block; padding-top: 1.25rem; }

/* Mind map */
.mindmap-label {
  font-size: .72rem; font-weight: 700; letter-spacing: .09em; text-transform: uppercase;
  color: #bba; margin-bottom: .75rem;
}
.mindmap-wrap { overflow-x: auto; padding-bottom: .5rem; }
.mindmap-svg { display: block; min-width: 560px; }
</style>

<!-- Hero -->
<section class="lop6-hero">
  <div class="lop6-hero-inner">
    <div>
      <span class="lop6-badge">Lớp 6</span>
      <h1>Lịch sử <span>6</span><br>Kết nối tri thức</h1>
      <p>Đầy đủ 5 chương · 19 bài học · Sơ đồ tư duy trực quan cho từng bài.</p>
      <div class="lop6-stats">
        <div class="lop6-stat"><strong>5</strong><span>Chương</span></div>
        <div class="lop6-stat"><strong>19</strong><span>Bài học</span></div>
        <div class="lop6-stat"><strong>19</strong><span>Sơ đồ tư duy</span></div>
      </div>
    </div>
  </div>
</section>

<!-- Main -->
<div class="lop6-main">

  <!-- Sidebar -->
  <aside class="lop6-sidebar">
    <div class="sidebar-title">Các chương</div>
    <nav class="chapter-nav" id="chapterNav">
      <% chapters.forEach(function(ch, i) { %>
      <div class="chapter-nav-item <%= i === 0 ? 'active' : '' %>" data-target="<%= ch.id %>">
        <span class="ch-icon"><%= ch.icon %></span>
        <span class="ch-label">Chương <%= ch.number %><br><span class="ch-num"><%= ch.title.length > 32 ? ch.title.substring(0,32)+'…' : ch.title %></span></span>
      </div>
      <% }) %>
    </nav>
  </aside>

  <!-- Content -->
  <main class="lop6-content" id="lop6Content">
    <% chapters.forEach(function(ch, ci) { %>
    <section class="chapter-section <%= ci === 0 ? 'active' : '' %>" id="<%= ch.id %>">

      <!-- Chapter header -->
      <div class="chapter-header">
        <div class="chapter-icon-big"><%= ch.icon %></div>
        <div class="chapter-header-text">
          <div class="ch-subtitle">Chương <%= ch.number %></div>
          <h2><%= ch.title %></h2>
          <p><%= ch.summary %></p>
        </div>
      </div>

      <!-- Lessons -->
      <div class="lessons-grid">
        <% ch.lessons.forEach(function(lesson, li) { %>
        <div class="lesson-card" id="lesson-<%= lesson.id %>">
          <div class="lesson-header" onclick="toggleLesson(this)">
            <div class="lesson-num">B<%= lesson.number %></div>
            <div class="lesson-title">Bài <%= lesson.number %>. <%= lesson.title %></div>
            <div class="lesson-toggle">▾</div>
          </div>
          <div class="lesson-body">
  <% if (lesson.pdf) { %>
  <div class="mindmap-label" style="margin-top:1.25rem;">Sách giáo khoa</div>
  <div style="border:1px solid #f0e8e0; border-radius:10px; overflow:hidden;">
    <iframe src="<%= lesson.pdf %>"
            width="100%" height="500px"
            style="display:block; border:none;">
    </iframe>
  </div>
  <a href="<%= lesson.pdf %>" target="_blank"
     style="display:inline-block; margin-top:.75rem; color:#ff7a1a; font-size:.88rem; font-weight:600;">
    ↗ Mở PDF trong tab mới
  </a>
  <% } %>

  <div class="mindmap-label" style="margin-top:1.25rem;">Sơ đồ tư duy</div>
  <div class="mindmap-wrap">
    <%- renderMindmap(lesson.mindmap, ch.color) %>
  </div>

  <% if (lesson.infographic) { %>
  <div class="mindmap-label" style="margin-top:1.25rem;">Infographic</div>
  <img src="<%= lesson.infographic %>"
       alt="Infographic <%= lesson.title %>"
       style="width:100%; border-radius:10px; margin-bottom:1.25rem; border:1px solid #f0e8e0;">
  <% } %>

</div>
        </div>
        <% }) %>
      </div>

    </section>
    <% }) %>
  </main>
</div>

<%- include('../partials/footer', { brand, resources: [], currentYear }) %>

<script>
// Chapter navigation
document.getElementById('chapterNav').addEventListener('click', function(e) {
  const item = e.target.closest('.chapter-nav-item');
  if (!item) return;
  document.querySelectorAll('.chapter-nav-item').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.chapter-section').forEach(el => el.classList.remove('active'));
  item.classList.add('active');
  document.getElementById(item.dataset.target).classList.add('active');
  window.scrollTo({ top: document.querySelector('.lop6-main').offsetTop - 20, behavior: 'smooth' });
});

// Lesson accordion
function toggleLesson(header) {
  const card = header.closest('.lesson-card');
  card.classList.toggle('open');
}
</script>

</body>
</html>
